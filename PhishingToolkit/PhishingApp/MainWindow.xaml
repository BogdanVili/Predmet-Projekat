<Window x:Class="PhishingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PhishingApp"
		xmlns:views ="clr-namespace:PhishingApp.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Email Sending"
                    Width="150"
                    Height="35"
                    Margin="10"
                    Click="EmailSendingView_Click"/>
            <Button Content="Victims"
                    Width="170"
                    Height="36"
                    Click="Exploited_Click"/>
        </StackPanel>

        <ContentControl x:Name="MainContent"
                        Grid.Row="1"/>
    </Grid>
</Window>
